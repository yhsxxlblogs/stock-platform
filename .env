# ==========================================
# MarketPulse 股票交易平台 - 环境变量配置
# ==========================================

# ------------------------------------------
# 基础配置
# ------------------------------------------

# 时区设置 (默认: Asia/Shanghai)
TZ=Asia/Shanghai

# ------------------------------------------
# MySQL 数据库配置
# ------------------------------------------

# MySQL root 密码 (必须修改！)
MYSQL_ROOT_PASSWORD=@Syh20050608

# 数据库名称
MYSQL_DATABASE=stock_platform

# MySQL 字符集
MYSQL_CHARSET=utf8mb4
MYSQL_COLLATION=utf8mb4_unicode_ci

# ------------------------------------------
# Redis 缓存配置
# ------------------------------------------

# Redis 端口 (宿主机映射端口)
REDIS_PORT=6380

# ------------------------------------------
# 后端服务配置
# ------------------------------------------

# 服务端口 (宿主机映射端口)
BACKEND_PORT=9090

# JWT 密钥 (生产环境必须修改为随机字符串！)
JWT_SECRET=stockPlatformSecretKey2026

# JWT 过期时间 (毫秒，默认7天)
JWT_EXPIRATION=604800000

# 文件上传路径
UPLOAD_DIR=/app/uploads

# JVM 内存配置
JAVA_OPTS=-Xms512m -Xmx1024m -Dfile.encoding=UTF-8

# ------------------------------------------
# 前端服务配置
# ------------------------------------------

# 前端端口 (宿主机映射端口)
FRONTEND_PORT=80

# API 基础路径 (用于前端代理)
VITE_API_BASE_URL=/api

# ------------------------------------------
# 股票数据同步配置
# ------------------------------------------

# 是否启用自动同步 (true/false)
STOCK_SYNC_ENABLED=true

# 同步间隔 (分钟)
STOCK_SYNC_INTERVAL=1440

# ------------------------------------------
# 日志配置
# ------------------------------------------

# 日志级别 (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# 日志文件路径
LOG_PATH=/app/logs

# ==========================================
# 安全提示：
# 1. 生产环境请务必修改 MYSQL_ROOT_PASSWORD
# 2. 生产环境请务必修改 JWT_SECRET 为随机字符串
# 3. 不要在版本控制中提交此文件
# ==========================================
