# ==========================================
# Stock Platform 环境变量配置示例
# 复制此文件为 .env 并修改配置
# ==========================================

# ------------------------------------------
# MySQL 数据库配置
# ------------------------------------------
MYSQL_ROOT_PASSWORD=your_secure_password_here
MYSQL_DATABASE=stock_platform

# ------------------------------------------
# 时区配置
# ------------------------------------------
TZ=Asia/Shanghai

# ------------------------------------------
# JWT 密钥配置（生产环境必须修改）
# 建议使用随机字符串，长度至少32位
# ------------------------------------------
JWT_SECRET=your_random_jwt_secret_key_min_32_chars

# ------------------------------------------
# Token 过期时间（毫秒）
# 默认 24 小时 = 86400000
# ------------------------------------------
JWT_EXPIRATION=86400000

# ------------------------------------------
# 服务器域名（用于CORS配置）
# 多个域名用逗号分隔
# ------------------------------------------
SERVER_DOMAIN=your-domain.com

# ------------------------------------------
# Docker Registry（可选）
# 如果使用私有镜像仓库
# ------------------------------------------
# DOCKER_REGISTRY=your-registry.com/
